    },
    {
      "id": "nextjs-nestjs-architecture",
      "description": "Frontend/backend separation, server components, APIs, NestJS modules, adapter patterns.",
      "when": ["nextjs", "nestjs"]
    },
    {
      "id": "ai-workflow-governance",
      "description": "AI-generated workflows, human approval, inactive drafts, governance, auditability.",
