    {
      "id": "n8n-automation-ops",
      "description": "n8n Queue Mode, workflow catalog, executions, workers, Redis, health checks.",
      "when": ["n8n"]
    },
    {
      "id": "aws-saas-platform",
      "description": "Cognito, RDS PostgreSQL, Secrets Manager, CloudFront, WAF, CloudWatch, CodePipeline, Terraform.",
